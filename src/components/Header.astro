---
import { NAV_LINKS } from "../consts";

const pathname = Astro.url.pathname.replace(/\/$/, "");
const homeHref = "/rajatjog-website/";

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "");
  if (normalized === "/rajatjog-website") return pathname === "/rajatjog-website";
  return pathname === normalized || pathname.startsWith(`${normalized}/`);
}
---

<header>
  <nav aria-label="Primary navigation">
    <a href={homeHref} class="site-mark" aria-label="Rajat Jog home">RJ</a>

    <div class="nav-right">
      <ul class="nav-links" id="navLinks">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class:list={{ active: isActive(link.href) }}>
                {link.label === "Blog" ? "Writing" : link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="accent-picker" id="accentPicker">
        <button class="accent-toggle" id="accentToggle" aria-label="Choose accent color" aria-expanded="false" title="Choose accent color">
          <span class="active-swatch" aria-hidden="true"></span>
        </button>
        <div class="accent-menu" id="accentMenu" aria-label="Accent color options">
          <button type="button" data-accent-choice="emerald" aria-label="Emerald accent"><span class="swatch emerald"></span></button>
          <button type="button" data-accent-choice="cyan" aria-label="Cyan accent"><span class="swatch cyan"></span></button>
          <button type="button" data-accent-choice="violet" aria-label="Violet accent"><span class="swatch violet"></span></button>
          <button type="button" data-accent-choice="amber" aria-label="Amber accent"><span class="swatch amber"></span></button>
          <button type="button" data-accent-choice="rose" aria-label="Rose accent"><span class="swatch rose"></span></button>
          <button type="button" data-accent-choice="blue" aria-label="Blue accent"><span class="swatch blue"></span></button>
          <button type="button" data-accent-choice="orange" aria-label="Orange accent"><span class="swatch orange"></span></button>
          <button type="button" data-accent-choice="purple" aria-label="Purple accent"><span class="swatch purple"></span></button>
          <button type="button" data-accent-choice="slate" aria-label="Slate accent"><span class="swatch slate"></span></button>
          <button type="button" data-accent-choice="indigo" aria-label="Indigo accent"><span class="swatch indigo"></span></button>
        </div>
      </div>

      <button class="theme-toggle" id="themeToggle" aria-label="Toggle color theme" title="Toggle color theme">
        <svg class="theme-icon sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg class="theme-icon moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5 7 7 0 1 0 20.5 14.5z"></path>
        </svg>
      </button>

      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  header {
    background: var(--header-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    width: 100%;
    z-index: 100;
  }

  nav {
    align-items: center;
    display: flex;
    height: 60px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: var(--max-width);
    padding: 0 2.5rem;
  }

  .site-mark {
    color: var(--color-accent) !important;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .site-mark:hover {
    color: var(--color-accent-hover) !important;
  }

  .nav-right {
    align-items: center;
    display: flex;
    gap: 1rem;
  }

  .nav-links {
    align-items: center;
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .theme-toggle {
    align-items: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: inline-flex;
    height: 36px;
    justify-content: center;
    padding: 0;
    transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
    width: 36px;
  }

  .accent-picker {
    position: relative;
  }

  .accent-toggle {
    align-items: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    cursor: pointer;
    display: inline-flex;
    height: 36px;
    justify-content: center;
    padding: 0;
    transition: border-color 0.18s ease, background 0.18s ease;
    width: 36px;
  }

  .accent-toggle:hover,
  .accent-picker.open .accent-toggle {
    background: var(--color-bg-secondary);
    border-color: var(--color-border-hover);
  }

  .active-swatch,
  .swatch {
    border-radius: 999px;
    display: block;
  }

  .active-swatch {
    background: var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent-glow);
    height: 14px;
    width: 14px;
  }

  .accent-menu {
    align-items: center;
    background: var(--color-surface);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.22);
    display: none;
    gap: 0.35rem;
    padding: 0.45rem;
    position: absolute;
    right: 0;
    top: calc(100% + 0.65rem);
  }

  .accent-picker.open .accent-menu {
    display: flex;
  }

  .accent-menu button {
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    display: flex;
    height: 28px;
    justify-content: center;
    padding: 0;
    width: 28px;
  }

  .accent-menu button:hover,
  .accent-menu button.active {
    border-color: var(--color-border-hover);
    background: var(--color-bg-secondary);
  }

  .swatch {
    height: 14px;
    width: 14px;
  }

  .swatch.emerald {
    background: oklch(0.72 0.16 145);
  }

  .swatch.cyan {
    background: oklch(0.76 0.13 205);
  }

  .swatch.violet {
    background: oklch(0.72 0.16 292);
  }

  .swatch.amber {
    background: oklch(0.78 0.15 72);
  }

  .swatch.rose {
    background: oklch(0.72 0.17 18);
  }

  .swatch.blue {
    background: oklch(0.7 0.16 250);
  }

  .swatch.orange {
    background: oklch(0.75 0.16 45);
  }

  .swatch.purple {
    background: oklch(0.7 0.16 280);
  }

  .swatch.slate {
    background: oklch(0.72 0.12 240);
  }

  .swatch.indigo {
    background: oklch(0.65 0.18 265);
  }

  .theme-toggle:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .theme-icon {
    display: none;
  }

  :global([data-theme="dark"]) .theme-icon.sun {
    display: block;
  }

  :global([data-theme="light"]) .theme-icon.moon {
    display: block;
  }

  .nav-links a {
    color: var(--color-text-secondary) !important;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0;
    text-decoration: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text) !important;
  }

  .menu-toggle {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--base-radius);
    color: var(--color-text);
    cursor: pointer;
    display: none;
    flex-direction: column;
    gap: 5px;
    height: 38px;
    justify-content: center;
    padding: 0 0.7rem;
    width: 42px;
  }

  .menu-toggle span {
    background: currentColor;
    border-radius: 2px;
    display: block;
    height: 2px;
    transition: transform 0.18s ease, opacity 0.18s ease;
    width: 18px;
  }

  .menu-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 720px) {
    nav {
      padding: 0 1.25rem;
    }

    .menu-toggle {
      display: flex;
    }

    .nav-links {
      background: var(--header-menu-bg);
      border-bottom: 1px solid var(--color-border);
      border-top: 1px solid var(--color-border);
      display: none;
      flex-direction: column;
      gap: 0;
      left: 0;
      padding: 0.5rem 0;
      position: absolute;
      right: 0;
      top: 60px;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links li {
      width: 100%;
    }

    .nav-links a {
      display: block;
      padding: 0.8rem 1.25rem;
      width: 100%;
    }

    .accent-menu {
      right: -2.85rem;
    }
  }
</style>

<script>
  const menuToggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("navLinks");
  const themeToggle = document.getElementById("themeToggle");
  const accentPicker = document.getElementById("accentPicker");
  const accentToggle = document.getElementById("accentToggle");
  const accentChoices = document.querySelectorAll("[data-accent-choice]");

  function setActiveAccentButton(accent: string) {
    accentChoices.forEach((button) => {
      button.classList.toggle("active", button.getAttribute("data-accent-choice") === accent);
    });
  }

  function setAccent(accent: string) {
    document.documentElement.dataset.accent = accent;
    localStorage.setItem("accentColor", accent);
    setActiveAccentButton(accent);
  }

  function setTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
  }

  setActiveAccentButton(document.documentElement.dataset.accent || "emerald");

  accentToggle?.addEventListener("click", (event) => {
    event.stopPropagation();
    const isOpen = accentPicker?.classList.toggle("open") ?? false;
    accentToggle.setAttribute("aria-expanded", String(isOpen));
  });

  accentChoices.forEach((button) => {
    button.addEventListener("click", () => {
      const accent = button.getAttribute("data-accent-choice") || "emerald";
      setAccent(accent);
      accentPicker?.classList.remove("open");
      accentToggle?.setAttribute("aria-expanded", "false");
    });
  });

  document.addEventListener("click", (event) => {
    if (!accentPicker?.contains(event.target as Node)) {
      accentPicker?.classList.remove("open");
      accentToggle?.setAttribute("aria-expanded", "false");
    }
  });

  themeToggle?.addEventListener("click", () => {
    const current = document.documentElement.dataset.theme || "dark";
    setTheme(current === "dark" ? "light" : "dark");
  });

  menuToggle?.addEventListener("click", () => {
    const isOpen = navLinks?.classList.toggle("open") ?? false;
    menuToggle.classList.toggle("open", isOpen);
    menuToggle.setAttribute("aria-expanded", String(isOpen));
  });

  navLinks?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      navLinks.classList.remove("open");
      menuToggle?.classList.remove("open");
      menuToggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
