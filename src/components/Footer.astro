---
import { SOCIAL_LINKS } from "../consts";
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-name">Rajat Jog</span>
        <span class="footer-tagline">Systems Over Syntax</span>
      </div>

      <div class="footer-nav">
        <div class="footer-col">
          <span class="footer-col-label">Work</span>
          <a href="/rajatjog-website/projects">Projects</a>
          <a href="/rajatjog-website/blog">Writing</a>
          <a href="/rajatjog-website/now">Now</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-label">Connect</span>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub</a
          >
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener"
            >LinkedIn</a
          >
          <a href={SOCIAL_LINKS.pypi} target="_blank" rel="noopener">PyPI</a>
          <a href={SOCIAL_LINKS.email}>Email</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-label">Open Source</span>
          <a
            href="https://pypi.org/project/timeblocks/"
            target="_blank"
            rel="noopener">timeblocks</a
          >
          <a
            href="https://pypi.org/project/django-system-audit/"
            target="_blank"
            rel="noopener">django-system-audit</a
          >
          <a
            href="https://pypi.org/project/django-ml-audit/"
            target="_blank"
            rel="noopener">django-ml-audit</a
          >
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">
        © {new Date().getFullYear()} Rajat Jog · Pune, India
      </span>
      <span class="footer-built">
        Built with <a href="https://astro.build" target="_blank" rel="noopener"
          >Astro</a
        >
        · Hosted on <a
          href="https://pages.github.com"
          target="_blank"
          rel="noopener">GitHub Pages</a
        >
      </span>
    </div>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    border-top: var(--glass-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    margin-top: 5rem;
    display: block;
    position: relative;
    overflow: hidden;
  }
  
  footer::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-accent-glow), transparent);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 1.5rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: 0.25rem;
  }

  .footer-col a {
    font-size: 0.95rem;
    color: var(--color-text-secondary) !important;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--color-accent) !important;
    transform: translateX(4px);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .footer-built {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .footer-built a {
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
  }

  .footer-built a:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-nav {
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
