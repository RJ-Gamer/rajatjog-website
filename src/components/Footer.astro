---
import { SOCIAL_LINKS } from "../consts";
---
 
<footer>
  <div class="footer-inner">
    <span class="footer-left">
      © {new Date().getFullYear()} Rajat Jog · Built with
      <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
    </span>

    <div class="footer-links">
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">
        GitHub
      </a>
      <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">
        LinkedIn
      </a>
      <a href={SOCIAL_LINKS.email}>
        Email
      </a>
      <a href={SOCIAL_LINKS.pypi} target="_blank" rel="noopener">
        PyPI
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-left a {
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  .footer-left a:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-secondary) !important;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-text) !important;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>