---
import { SOCIAL_LINKS } from "../consts";
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/rajatjog-website/" class="footer-mark">RJ</a>
        <div>
          <strong>Rajat Jog</strong>
          <p>Senior Backend Engineer building systems that last.</p>
        </div>
      </div>

      <div class="footer-grid">
        <div class="footer-col">
          <span>Navigate</span>
          <a href="/rajatjog-website/about">About</a>
          <a href="/rajatjog-website/projects">Projects</a>
          <a href="/rajatjog-website/blog">Writing</a>
          <a href="/rajatjog-website/now">Now</a>
          <a href="/rajatjog-website/contact">Contact</a>
        </div>

        <div class="footer-col">
          <span>Connect</span>
          <a href={SOCIAL_LINKS.email}>Email</a>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub</a>
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={SOCIAL_LINKS.pypi} target="_blank" rel="noopener">PyPI</a>
        </div>

        <div class="footer-col">
          <span>Open Source</span>
          <a href="https://pypi.org/project/timeblocks/" target="_blank" rel="noopener">timeblocks</a>
          <a href="https://pypi.org/project/django-system-audit/" target="_blank" rel="noopener">django-system-audit</a>
          <a href="https://pypi.org/project/django-ml-audit/" target="_blank" rel="noopener">django-ml-audit</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Rajat Jog / Pune, India</span>
      <span>Systems Over Syntax / Built with Astro</span>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    display: block;
    margin-top: auto;
    width: 100%;
  }

  .footer-inner {
    margin: 0 auto;
    max-width: var(--max-width);
    padding: 3rem 2.5rem 1.5rem;
  }

  .footer-top {
    display: grid;
    gap: 4rem;
    grid-template-columns: minmax(220px, 1fr) minmax(0, 1.5fr);
    padding-bottom: 2.5rem;
  }

  .footer-brand {
    display: flex;
    gap: 1rem;
  }

  .footer-mark {
    align-items: center;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent-border);
    border-radius: 999px;
    color: var(--color-accent) !important;
    display: inline-flex;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    height: 42px;
    justify-content: center;
    text-decoration: none;
    width: 42px;
  }

  .footer-brand strong {
    color: var(--color-text);
    display: block;
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
  }

  .footer-brand p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    max-width: 280px;
  }

  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col span,
  .footer-bottom span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-col span {
    margin-bottom: 0.3rem;
  }

  .footer-col a {
    color: var(--color-text-secondary);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .footer-col a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    align-items: center;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    padding-top: 1.5rem;
  }

  @media (max-width: 820px) {
    .footer-top,
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-top {
      gap: 2.5rem;
    }
  }

  @media (max-width: 720px) {
    .footer-inner {
      padding: 2.5rem 1.25rem 1.5rem;
    }
  }
</style>
