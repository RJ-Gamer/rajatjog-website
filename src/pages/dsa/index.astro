---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Fetch the DSA repo tree from GitHub API at build time
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN; // optional, increases rate limit
const headers = GITHUB_TOKEN
  ? { Authorization: `token ${GITHUB_TOKEN}` }
  : {};

// Fetch repo contents
let problems = [];
try {
  const res = await fetch(
    "https://api.github.com/repos/RJ-Gamer/DSA-SOLVED/contents/DSA",
    { headers }
  );
  const folders = await res.json();

  // For each folder, fetch its README to get frontmatter-like data
  problems = folders
    .filter((item) => item.type === "dir")
    .map((folder) => {
      // Parse number and name from folder name like "01_two_sum"
      const match = folder.name.match(/^(\d+)_(.+)$/);
      const number = match ? match[1] : folder.name;
      const slug = match ? match[2] : folder.name;
      const title = slug
        .split("_")
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
        .join(" ");

      return {
        number: parseInt(number),
        title,
        slug: folder.name,
        githubUrl: `https://github.com/RJ-Gamer/DSA-SOLVED/tree/main/DSA/${folder.name}`,
        href: `/rajatjog-website/dsa/${folder.name}`,
      };
    })
    .sort((a, b) => a.number - b.number);
} catch (e) {
  console.error("Failed to fetch DSA problems from GitHub", e);
}

// Manually add difficulty and topics since GitHub API can't infer these
// Update this map as you add problems
const metadata = {
  "01_two_sum":                      { difficulty: "Easy",   topics: ["Array", "Hash Map"] },
  "53_maximum_subarray":             { difficulty: "Medium", topics: ["Array", "Dynamic Programming"] },
  "62_unique_paths":                 { difficulty: "Medium", topics: ["Dynamic Programming", "Math"] },
  "63_unique_paths_II":              { difficulty: "Medium", topics: ["Dynamic Programming"] },
  "70_climbing_stairs":              { difficulty: "Easy",   topics: ["Dynamic Programming"] },
  "72_min_distance":                 { difficulty: "Medium", topics: ["String", "Dynamic Programming"] },
  "121_best_time_to_buy_and_sell":   { difficulty: "Easy",   topics: ["Array", "Greedy"] },
  "125_valid_palindrome":            { difficulty: "Easy",   topics: ["String", "Two Pointers"] },
  "217_contains_duplicate":          { difficulty: "Easy",   topics: ["Array", "Hash Map"] },
  "242_valid_anagram":               { difficulty: "Easy",   topics: ["String", "Hash Map"] },
  "516_longest_palindrome_subsequence": { difficulty: "Medium", topics: ["String", "Dynamic Programming"] },
  "647_palindrome_substrings":       { difficulty: "Medium", topics: ["String", "Dynamic Programming"] },
  "746_min_cost_climbing_stairs":    { difficulty: "Easy",   topics: ["Dynamic Programming"] },
  "1143_longest_common_subsequence": { difficulty: "Medium", topics: ["String", "Dynamic Programming"] },
};

// Merge metadata
problems = problems.map((p) => ({
  ...p,
  ...(metadata[p.slug] || { difficulty: "—", topics: [] }),
}));

const easy   = problems.filter((p) => p.difficulty === "Easy").length;
const medium = problems.filter((p) => p.difficulty === "Medium").length;
const hard   = problems.filter((p) => p.difficulty === "Hard").length;
const allTopics = [...new Set(problems.flatMap((p) => p.topics))];
const latestProblem = problems.at(-1);
---

<html lang="en">
  <head>
    <BaseHead
      title="DSA — Rajat Jog"
      description={`${problems.length} DSA problems solved in Python with detailed explanations, patterns, and real-world use cases.`}
    />
  </head>
  <body style="min-height: 100vh; display: flex; flex-direction: column;">
    <Header />

    <main style="flex: 1;">
      <section class="page-header">
        <div class="page-header-grid">
          <div>
            <span class="page-kicker">DSA</span>
            <h1>
              Solved problems,<br />
              <span>pattern first.</span>
            </h1>
            <p class="page-subtitle">
              Python solutions with explanations, reusable patterns, and
              production context where it helps.
            </p>
          </div>

          <aside class="page-header-side dsa-header-side">
            <div>
              <span>Collection</span>
              <strong>{problems.length} solved problems</strong>
            </div>
            <div>
              <span>Topics</span>
              <strong>{allTopics.length} recurring patterns</strong>
            </div>
            <div>
              <span>Latest addition</span>
              <strong>{latestProblem ? latestProblem.title : "Updating soon"}</strong>
            </div>
          </aside>
        </div>
      </section>

      <section class="filter-panel" aria-label="Problem filters">
        <div class="filter-head">
          <div>
            <span class="section-label">Browse by difficulty</span>
            <p>Filter the collection without changing the page structure.</p>
          </div>
          <span class="filter-count">{problems.length} total</span>
        </div>

        <div class="page-header-stats stats-row">
          <button class="stat active" data-difficulty="all">
            <span class="stat-val">{problems.length}</span>
            <span class="stat-lbl">Total</span>
          </button>
          <button class="stat" data-difficulty="easy">
            <span class="stat-val easy">{easy}</span>
            <span class="stat-lbl">Easy</span>
          </button>
          <button class="stat" data-difficulty="medium">
            <span class="stat-val medium">{medium}</span>
            <span class="stat-lbl">Medium</span>
          </button>
          <button class="stat" data-difficulty="hard">
            <span class="stat-val hard">{hard}</span>
            <span class="stat-lbl">Hard</span>
          </button>
        </div>
      </section>

      {problems.length === 0 ? (
        <div class="empty-state">
          <p>Could not load problems. View them directly on
            <a href="https://github.com/RJ-Gamer/DSA-SOLVED" target="_blank" rel="noopener">
              GitHub
            </a>.
          </p>
        </div>
      ) : (
        <div class="problem-list">
          {problems.map((problem) => (
            <a
              href={problem.href}
              class="problem-row"
              data-difficulty={problem.difficulty.toLowerCase()}
            >
              <span class="problem-number">#{problem.number}</span>
              <span class="problem-title">{problem.title}</span>
              <div class="problem-topics">
                {problem.topics.map((topic) => (
                  <span class="badge">{topic}</span>
                ))}
              </div>
              <span class={`difficulty difficulty-${problem.difficulty === "—" ? "unknown" : problem.difficulty.toLowerCase()}`}>
                {problem.difficulty}
              </span>
              <span class="problem-arrow">→</span>
            </a>
          ))}
        </div>
      )}

      <div class="github-link">
        <a
          href="https://github.com/RJ-Gamer/DSA-SOLVED"
          target="_blank"
          rel="noopener"
          class="btn-secondary"
        >
          View on GitHub →
        </a>
      </div>

    </main>

    <Footer />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const filterButtons = document.querySelectorAll(".stats-row .stat");
        const problemRows = document.querySelectorAll(".problem-row") as NodeListOf<HTMLElement>;

        filterButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const selectedDifficulty = (button as HTMLElement).dataset.difficulty;

            // Update active state
            filterButtons.forEach((btn) => btn.classList.remove("active"));
            button.classList.add("active");

            // Filter problems
            problemRows.forEach((row) => {
              const difficulty = row.dataset.difficulty;
              if (selectedDifficulty === "all" || difficulty === selectedDifficulty) {
                row.style.display = "flex";
              } else {
                row.style.display = "none";
              }
            });
          });
        });
      });
    </script>
  </body>
</html>

<style>
  .dsa-header-side {
    display: flex;
    flex-direction: column;
  }

  .dsa-header-side div {
    align-items: baseline;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .dsa-header-side span,
  .section-label,
  .filter-count {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dsa-header-side strong {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 400;
    max-width: 180px;
    text-align: right;
  }

  .filter-panel {
    border-top: 1px solid var(--color-border);
    margin-top: 5rem;
    padding-top: 4rem;
  }

  .filter-head {
    align-items: end;
    display: flex;
    gap: 1.5rem;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .filter-head p {
    font-size: 0.9rem;
    margin: 0.5rem 0 0;
    max-width: 30rem;
  }

  .stats-row {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--base-radius);
    padding: 1rem 1.1rem;
    min-width: 0;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    text-align: left;
  }

  .stat:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-strong);
  }

  .stat.active {
    background: var(--color-surface-strong);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  .stat-val {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .stat-val.easy   { color: #16a34a; }
  .stat-val.medium { color: #d97706; }
  .stat-val.hard   { color: #dc2626; }

  .stat-lbl {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .problem-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .problem-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.15s ease;
    flex-wrap: wrap;
  }

  .problem-row:last-child {
    border-bottom: none;
  }

  .problem-row:hover {
    background: var(--color-bg-secondary);
  }

  .problem-number {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    min-width: 36px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .problem-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    flex: 1;
    min-width: 140px;
  }

  .problem-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    flex: 1;
  }

  .difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .difficulty-easy    { color: #16a34a; }
  .difficulty-medium  { color: #d97706; }
  .difficulty-hard    { color: #dc2626; }
  .difficulty-unknown { color: var(--color-text-secondary); }

  .problem-arrow {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .problem-row:hover .problem-arrow {
    color: var(--color-accent);
  }

  .empty-state {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text-secondary);
  }

  .github-link {
    margin-top: 2rem;
  }

  @media (max-width: 820px) {
    .filter-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .stats-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .problem-topics { display: none; }
    .problem-row { gap: 0.75rem; }
  }
</style>
