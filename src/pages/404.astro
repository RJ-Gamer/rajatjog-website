---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
---

<html lang="en">
  <head>
    <BaseHead
      title="404 - Page Not Found / Rajat Jog"
      description="This page does not exist."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="not-found">
        <span class="page-kicker">404</span>
        <h1>
          Page not found,<br />
          <span>probably a bad link.</span>
        </h1>
        <p>
          This page does not exist or was moved. The useful doors are still
          right here.
        </p>

        <div class="error-actions">
          <a href="/rajatjog-website/" class="btn-primary">Go home</a>
          <a href="/rajatjog-website/projects" class="btn-secondary">View projects</a>
        </div>

        <div class="error-links">
          <a href="/rajatjog-website/about">About -></a>
          <a href="/rajatjog-website/blog">Writing -></a>
          <a href="/rajatjog-website/now">Now -></a>
          <a href="/rajatjog-website/contact">Contact -></a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .not-found {
    max-width: 680px;
    padding: 3rem 0;
  }

  .not-found h1 span {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .not-found p {
    max-width: 460px;
  }

  .error-actions,
  .error-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .error-actions {
    margin: 2rem 0 3rem;
  }

  .error-links {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .error-links a {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .error-links a:hover {
    color: var(--color-accent);
  }
</style>
