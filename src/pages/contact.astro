---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SOCIAL_LINKS } from "../consts";

const links = [
  ["Email", "rajatjog1294@gmail.com", "Replies within 24 hours", SOCIAL_LINKS.email],
  ["LinkedIn", "linkedin.com/in/rajat-jog", "Professional network", SOCIAL_LINKS.linkedin],
  ["GitHub", "github.com/RJ-Gamer", "Open source work", SOCIAL_LINKS.github],
  ["PyPI", "pypi.org/user/rajatjog1294", "3 published packages", SOCIAL_LINKS.pypi],
];

const topics = [
  ["Work", "Open to Senior Backend Engineer, Backend Tech Lead, and Staff Engineer roles. Remote-first, open to international opportunities."],
  ["Open Source", "Interested in contributing to timeblocks, django-system-audit, or django-ml-audit? PRs, issues, and conversations welcome."],
  ["Anything else", "Building something in Django, healthtech, fintech, or developer tooling? I am happy to talk."],
];
---

<html lang="en">
  <head>
    <BaseHead
      title="Contact - Rajat Jog"
      description="Get in touch with Rajat Jog - Senior Backend Engineer open to remote roles."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <div class="page-header-note">Replies within 24 hours</div>
        <span class="page-kicker">Contact</span>
        <h1>
          Get in touch,<br />
          <span>let's build something useful.</span>
        </h1>
        <p class="page-subtitle">
          Whether it is about a role, a collaboration, or just something you
          are building, I am happy to talk.
        </p>
      </section>

      <section class="contact-layout">
        <div>
          <p class="section-label">Send a message</p>
          <form id="contactForm" class="contact-form">
            <div class="form-grid">
              <label>
                <span>Name</span>
                <input id="name" name="name" autocomplete="name" />
              </label>
              <label>
                <span>Email</span>
                <input id="email" name="email" type="email" autocomplete="email" />
              </label>
            </div>
            <label>
              <span>Subject</span>
              <input id="subject" name="subject" />
            </label>
            <label>
              <span>Message</span>
              <textarea id="message" name="message" rows="7" placeholder="What are you working on? Or just say hi."></textarea>
            </label>
            <div class="form-actions">
              <button class="btn-primary" type="submit">Send message -></button>
              <span id="formStatus" aria-live="polite"></span>
            </div>
            <p class="form-note">
              This opens your mail client. You can also write directly to
              <a href={SOCIAL_LINKS.email}>rajatjog1294@gmail.com</a>.
            </p>
          </form>
        </div>

        <aside class="contact-side">
          <section>
            <p class="section-label">Good reasons to write</p>
            <div class="topic-list">
              {topics.map(([label, description]) => (
                <div class="topic">
                  <h2><span>-></span>{label}</h2>
                  <p>{description}</p>
                </div>
              ))}
            </div>
          </section>

          <section>
            <p class="section-label">Find me on</p>
            <div class="link-list">
              {links.map(([label, value, sub, href]) => (
                <a href={href} target={href.startsWith("mailto") ? undefined : "_blank"} rel="noopener" class="contact-link">
                  <div class="link-icon">{label.slice(0, 1)}</div>
                  <div>
                    <strong>{value}</strong>
                    <span>{sub}</span>
                  </div>
                  <i>-&gt;</i>
                </a>
              ))}
            </div>
          </section>
        </aside>
      </section>

      <section class="contact-strip">
        <div>
          <span>Based in</span>
          <strong>Pune, India / IST (UTC +5:30)</strong>
        </div>
        <div>
          <span>Availability</span>
          <strong>Open to roles - remote-first</strong>
        </div>
        <div>
          <span>Response time</span>
          <strong>Within 24 hours</strong>
        </div>
      </section>
    </main>

    <Footer />

    <script>
      const form = document.getElementById("contactForm");
      const status = document.getElementById("formStatus");

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const name = data.get("name")?.toString() ?? "";
        const email = data.get("email")?.toString() ?? "";
        const subject = data.get("subject")?.toString() || "Message from portfolio";
        const message = data.get("message")?.toString() ?? "";
        const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;
        window.location.href = `mailto:rajatjog1294@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        if (status) status.textContent = "Opening your mail client...";
      });
    </script>
  </body>
</html>

<style>
  .contact-layout {
    display: grid;
    gap: 4rem;
    grid-template-columns: minmax(0, 1fr) 340px;
  }

  .section-label {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .contact-form,
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .contact-form {
    gap: 1.25rem;
  }

  .contact-form label span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .form-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  #formStatus,
  .form-note {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .form-note {
    margin: 0;
  }

  .contact-side {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .topic-list {
    border-top: 1px solid var(--color-border);
  }

  .topic {
    border-bottom: 1px solid var(--color-border);
    padding: 1.1rem 0;
  }

  .topic h2 {
    align-items: baseline;
    display: flex;
    font-size: 0.9rem;
    font-weight: 500;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .topic h2 span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .topic p {
    font-size: 0.84rem;
    margin: 0;
    padding-left: 1.25rem;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-link {
    align-items: center;
    border: 1px solid var(--color-border);
    color: inherit;
    display: flex;
    gap: 1rem;
    padding: 1rem;
  }

  .contact-link:hover {
    background: var(--color-bg-secondary);
    color: inherit;
  }

  .link-icon {
    align-items: center;
    background: var(--color-surface-strong);
    border: 1px solid var(--color-border);
    border-radius: var(--base-radius);
    color: var(--color-accent);
    display: flex;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    height: 38px;
    justify-content: center;
    width: 38px;
  }

  .contact-link div:not(.link-icon) {
    min-width: 0;
  }

  .contact-link strong {
    color: var(--color-text);
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-link span {
    color: var(--color-text-muted);
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    margin-top: 0.15rem;
  }

  .contact-link i {
    color: var(--color-text-muted);
    font-style: normal;
    margin-left: auto;
  }

  .contact-strip {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 5rem;
    padding-top: 2.5rem;
  }

  .contact-strip span {
    color: var(--color-text-muted);
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
  }

  .contact-strip strong {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 400;
  }

  @media (max-width: 900px) {
    .contact-layout,
    .contact-strip {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
