---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { nowItems } from "../data/pages/now";
import "../styles/pages/now.css";
---

<html lang="en">
  <head>
    <BaseHead
      title="Now - Rajat Jog"
      description="What Rajat Jog is currently focused on - updated April 2026."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <span class="page-kicker">Now</span>
        <h1>
          Current focus,<br />
          <span>April 2026.</span>
        </h1>
        <p class="page-subtitle">
          What I am currently focused on. Updated April 2026 from Pune, India.
        </p>
      </section>

      <section class="now-list">
        {nowItems.map(([label, content]) => (
          <article class="now-item">
            <h2>{label}</h2>
            <p>
              {label === "Writing" ? (
                <>
                  Publishing weekly on
                  <a href="https://linkedin.com/in/rajat-jog" target="_blank" rel="noopener"> LinkedIn</a>
                  {" "}about Django system design, backend engineering, and building in public.
                </>
              ) : content}
            </p>
          </article>
        ))}
      </section>

      <section class="now-footer">
        <p>
          This is a
          <a href="https://nownownow.com/about" target="_blank" rel="noopener"> /now page</a>
          - inspired by Derek Sivers. It changes when my focus changes.
        </p>
      </section>
    </main>

    <Footer />
  </body>
</html>
