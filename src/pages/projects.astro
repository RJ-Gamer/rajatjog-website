---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const projectGroups = [
  {
    category: "Client Projects",
    items: [
      {
        title: "OppVenuz",
        badgeLabel: "E-Commerce",
        badgeClass: "badge",
        duration: "Jun 2023 – Nov 2024",
        association: "Associated with Mindbowser Inc",
        bullets: [
          "Architected and developed the complete backend infrastructure for Oppvenuz, ensuring seamless integration of vendor listings, user profiles, and booking functionalities.",
          "Designed and implemented scalable RESTful APIs using Django and Django REST Framework (DRF) to support dynamic content delivery and user interactions across the platform.",
          "Optimized database schemas and queries for PostgreSQL, enhancing data retrieval speeds and overall application performance.",
          "Implemented caching strategies using Redis to reduce server load and improve response times for high-traffic endpoints."
        ],
        stack: ["Django", "DRF", "PostgreSQL", "Redis"],
        links: [
          { label: "Website", href: "https://www.oppvenuz.com/" }
        ]
      },
      {
        title: "Allday | Dayo",
        badgeLabel: "Mobile App",
        badgeClass: "badge",
        duration: "Jan 2023 – Feb 2024",
        association: "Associated with Mindbowser Inc",
        bullets: [
          "Architected and developed the complete backend infrastructure for Dayo, facilitating seamless user interactions and reward mechanisms.",
          "Designed and implemented scalable RESTful APIs using Django and Django REST Framework (DRF) to support real-time data synchronization and user engagement features.",
          "Built and integrated a custom Shopify marketplace to support the in-app redemption of wellness rewards, offering seamless product discovery and purchase experiences.",
          "Utilized LLM-based summarization tools to generate concise user insights and analytics dashboards."
        ],
        stack: ["Django", "DRF", "Shopify", "LLMs"],
      }
    ]
  },
  {
    category: "Open Source Projects",
    items: [
      {
        title: "django-system-audit",
        badgeLabel: "PyPI",
        badgeClass: "badge badge-pypi",
        why: "Signals capture effects. Compliance systems need to capture intent.",
        bullets: [
          "Intent-aware audit trail library for Django and DRF.",
          "Records audit events explicitly through views and admin actions rather than relying on signals — capturing why something happened, not just that it did.",
          "Built for HIPAA and SOC2 environments where audit logs must be legally defensible."
        ],
        stack: ["Python", "Django", "DRF"],
        links: [
          { label: "PyPI", href: "https://pypi.org/project/django-system-audit/" },
          {
            label: "GitHub",
            href: "https://github.com/RJ-Gamer/django-system-audit",
          },
        ],
      },
      {
        title: "timeblocks",
        badgeLabel: "PyPI",
        badgeClass: "badge badge-pypi",
        why: "Healthcare scheduling fails because availability is modelled as mutable state, not invariants.",
        bullets: [
          "Recurring time availability scheduling for Django.",
          "Handles daily, weekly, custom weekday, monthly, and yearly patterns with concurrency-safe slot generation.",
          "Changing availability never corrupts already-booked records — the core invariant most scheduling systems violate."
        ],
        stack: ["Python", "Django"],
        links: [
          { label: "PyPI", href: "https://pypi.org/project/timeblocks/" },
          { label: "GitHub", href: "https://github.com/RJ-Gamer/timeblocks" },
        ],
      },
      {
        title: "django-ml-audit",
        badgeLabel: "PyPI",
        badgeClass: "badge badge-pypi",
        why: "Debugging a strange ML prediction from last month shouldn't require excavating logs across 5 services.",
        bullets: [
          "Per-prediction ML audit trails for Django production systems.",
          "Records model version, redacted inputs, outputs, confidence scores, and SHAP explanations against real production traffic.",
          "Answers: what did the model do, which version, and why."
        ],
        stack: ["Python", "Django", "DRF"],
        links: [
          { label: "PyPI", href: "https://pypi.org/project/django-ml-audit/" },
          { label: "GitHub", href: "https://github.com/RJ-Gamer/django-ml-audit" },
        ],
      },
    ]
  }
];
---

<html lang="en">
  <head>
    <BaseHead
      title="Projects — Rajat Jog"
      description="Open source libraries, SaaS products, and production systems built by Rajat Jog."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <h1>Projects</h1>
        <p class="page-subtitle">
          Production systems, open source libraries, and side projects.
        </p>
      </section>

      <hr />

      <section class="projects-section">
        {projectGroups.map((group) => (
          <div class="project-group">
            <h2 class="group-category">{group.category}</h2>
            {
              group.items.map((project) => (
                <article class="project">
                  <div class="project-header">
                    <div class="project-title-row">
                      <h3 class="project-title">{project.title}</h3>
                      {project.badgeLabel && <span class={project.badgeClass}>{project.badgeLabel}</span>}
                    </div>
                    {project.duration && (
                      <p class="project-meta">{project.duration} • {project.association}</p>
                    )}
                    {project.why && <p class="project-why">"{project.why}"</p>}
                  </div>

                  {project.description && <p class="project-description">{project.description}</p>}
                  {project.bullets && project.bullets.length > 0 && (
                    <ul class="project-bullets">
                      {project.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  )}

                  <div class="project-footer">
                    <div class="project-stack">
                      {project.stack.map((tag) => (
                        <span class="badge">{tag}</span>
                      ))}
                    </div>
                    {project.links && project.links.length > 0 && (
                      <div class="project-links">
                        {project.links.map((link) => (
                          <a
                            href={link.href}
                            target="_blank"
                            rel="noopener"
                            class="project-link"
                          >
                            {link.label} →
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              ))
            }
          </div>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-header h1 {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--color-text), var(--color-text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.04em;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .projects-section {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project {
    padding: 2.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: var(--glass-border);
    border-radius: var(--base-radius);
    box-shadow: var(--glass-shadow);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 0 1px var(--color-accent-glow);
    border-color: var(--color-border-hover);
  }

  .project:last-child {
    border-bottom: none;
  }

  .group-category {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .project-group:first-child .group-category {
    margin-top: 0;
  }

  .project-meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin: -0.2rem 0 0 0;
  }

  .project-bullets {
    margin: 0.5rem 0 0 0;
    padding-left: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    list-style-type: disc;
  }

  .project-bullets li {
    margin-bottom: 0.4rem;
    padding-left: 0.2rem;
  }

  .project-bullets li:last-child {
    margin-bottom: 0;
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .project-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .project-why {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
    max-width: 580px;
  }

  .project-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 620px;
    margin: 0;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-links {
    display: flex;
    gap: 1.25rem;
  }

  .project-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent) !important;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .project-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 640px) {
    .project-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
