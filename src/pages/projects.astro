---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const projects = [
  {
    title: "APIHealthHub",
    badgeLabel: "LIVE",
    badgeClass: "badge badge-live",
    why: "Because knowing your API is down before your users do shouldn't require a Datadog contract.",
    description:
      "Lightweight API monitoring and public status pages for indie developers and small teams. Automated HTTP pings every 5 minutes, email alerts with smart deduplication (requires 2 consecutive UP pings to confirm recovery), and shareable status pages at /status/username.",
    stack: ["Django", "Celery", "PostgreSQL", "Redis", "Railway"],
    links: [
      { label: "Live Site", href: "https://yourdomain.com" },
      { label: "GitHub", href: "https://github.com/RJ-Gamer" },
    ],
  },
  {
    title: "django-system-audit",
    badgeLabel: "PyPI",
    badgeClass: "badge badge-pypi",
    why: "Signals capture effects. Compliance systems need to capture intent.",
    description:
      "Intent-aware audit trail library for Django and DRF. Records audit events explicitly through views and admin actions rather than relying on signals — capturing why something happened, not just that it did. Built for HIPAA and SOC2 environments where audit logs must be legally defensible.",
    stack: ["Python", "Django", "DRF"],
    links: [
      { label: "PyPI", href: "https://pypi.org/project/django-system-audit/" },
      {
        label: "GitHub",
        href: "https://github.com/RJ-Gamer/django-system-audit",
      },
    ],
  },
  {
    title: "timeblocks",
    badgeLabel: "PyPI",
    badgeClass: "badge badge-pypi",
    why: "Healthcare scheduling fails because availability is modelled as mutable state, not invariants.",
    description:
      "Recurring time availability scheduling for Django. Handles daily, weekly, custom weekday, monthly, and yearly patterns with concurrency-safe slot generation. Changing availability never corrupts already-booked records — the core invariant most scheduling systems violate.",
    stack: ["Python", "Django"],
    links: [
      { label: "PyPI", href: "https://pypi.org/project/timeblocks/" },
      { label: "GitHub", href: "https://github.com/RJ-Gamer/timeblocks" },
    ],
  },
  {
    title: "django-ml-audit",
    badgeLabel: "PyPI",
    badgeClass: "badge badge-pypi",
    why: "Debugging a strange ML prediction from last month shouldn't require excavating logs across 5 services.",
    description:
      "Per-prediction ML audit trails for Django production systems. Records model version, redacted inputs, outputs, confidence scores, and SHAP explanations against real production traffic. Answers: what did the model do, which version, and why.",
    stack: ["Python", "Django", "DRF"],
    links: [
      { label: "PyPI", href: "https://pypi.org/project/django-ml-audit/" },
      { label: "GitHub", href: "https://github.com/RJ-Gamer/django-ml-audit" },
    ],
  },
];
---

<html lang="en">
  <head>
    <BaseHead
      title="Projects — Rajat Jog"
      description="Open source libraries, SaaS products, and production systems built by Rajat Jog."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <h1>Projects</h1>
        <p class="page-subtitle">
          Production systems, open source libraries, and side projects.
        </p>
      </section>

      <hr />

      <section class="projects-section">
        {
          projects.map((project) => (
            <article class="project">
              <div class="project-header">
                <div class="project-title-row">
                  <h2 class="project-title">{project.title}</h2>
                  <span class={project.badgeClass}>{project.badgeLabel}</span>
                </div>
                <p class="project-why">"{project.why}"</p>
              </div>

              <p class="project-description">{project.description}</p>

              <div class="project-footer">
                <div class="project-stack">
                  {project.stack.map((tag) => (
                    <span class="badge">{tag}</span>
                  ))}
                </div>
                <div class="project-links">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener"
                      class="project-link"
                    >
                      {link.label} →
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .projects-section {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project:last-child {
    border-bottom: none;
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .project-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .project-why {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
    max-width: 580px;
  }

  .project-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 620px;
    margin: 0;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-links {
    display: flex;
    gap: 1.25rem;
  }

  .project-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent) !important;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .project-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 640px) {
    .project-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
