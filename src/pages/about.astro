---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SOCIAL_LINKS } from "../consts";
---

<html lang="en">
  <head>
    <BaseHead
      title="About — Rajat Jog"
      description="Senior Backend Engineer from Pune, India. Python, Django, FastAPI. Building systems that last."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <h1>About</h1>
        <p class="page-subtitle">
          Senior Backend Engineer · Pune, India · Remote-first
        </p>
      </section>

      <hr />

      <section class="section">
        <p>
          I'm Rajat — a senior backend engineer with 7+ years building
          production systems in healthtech and fintech. I specialise in Python,
          Django, and FastAPI. I care about systems that are correct, not just
          fast.
        </p>
        <p>
          My approach is captured in three words: <strong
            >Systems Over Syntax.</strong
          >
          Good engineering isn't about knowing more frameworks — it's about understanding
          what you're building and why. I think in invariants before I think in tables.
          I care about explicit logic over clever abstractions, strict database constraints
          over application-layer hope, and idempotency over optimism.
        </p>
        <p>
          I've spent most of my career at the intersection of compliance and
          performance — building HIPAA and SOC2-compliant platforms where "it
          works" isn't enough if it isn't auditable, and where a double-booked
          room isn't a bug, it's an operational failure.
        </p>
      </section>

      <hr />

      <section class="section">
        <h2>What I've built</h2>
        <p>I open-source the hard parts. Three libraries on PyPI:</p>
        <ul class="project-list">
          <li>
            <a
              href="https://pypi.org/project/timeblocks/"
              target="_blank"
              rel="noopener"
            >
              timeblocks
            </a>
            — recurring time availability scheduling for Django. Built after hitting
            the invariants problem in a production healthcare scheduling system.
          </li>
          <li>
            <a
              href="https://pypi.org/project/django-system-audit/"
              target="_blank"
              rel="noopener"
            >
              django-system-audit
            </a>
            — intent-aware audit trails for Django and DRF. Built because signal-based
            audit logging is architecturally broken for compliance systems.
          </li>
          <li>
            <a
              href="https://pypi.org/project/django-ml-audit/"
              target="_blank"
              rel="noopener"
            >
              django-ml-audit
            </a>
            — per-prediction ML audit trails for Django. Built because debugging a
            strange prediction from last month shouldn't require excavating logs across
            5 services.
          </li>
        </ul>
      </section>

      <hr />

      <section class="section">
        <h2>Experience</h2>
        <div class="experience-list">
          <div class="experience-item">
            <div class="experience-header">
              <span class="experience-role">Senior Software Engineer</span>
              <span class="experience-period">Feb 2024 — Present</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">Mindbowser Inc</span>
                <span class="badge-shield-value green">Remote</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Integrated production ML workflows using AWS SageMaker for
                predictive healthcare analytics
              </li>
              <li>
                Engineered HIPAA and SOC2-compliant platforms using HL7 and FHIR
                protocols
              </li>
              <li>
                Led 5+ engineers, reduced production bugs 25%, accelerated
                delivery by 6 weeks
              </li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <span class="experience-role">Software Engineer</span>
              <span class="experience-period">Nov 2022 — Feb 2024</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">Mindbowser Inc</span>
                <span class="badge-shield-value green">Remote</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Reduced API latency 60% via PostgreSQL indexing and Redis
                caching
              </li>
              <li>
                Architected Django and FastAPI backends for 5k DAU, 300 RPM
                healthcare platforms
              </li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <span class="experience-role">Software Engineer</span>
              <span class="experience-period">Apr 2022 — Nov 2022</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">KiwiTech</span>
                <span class="badge-shield-value green">Remote</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Scaled RESTful APIs for 7+ clients handling 5–7 GB daily data
                throughput
              </li>
              <li>
                Built Celery task queues for 15+ daily background jobs — zero
                missed deliveries
              </li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <span class="experience-role">Python Developer</span>
              <span class="experience-period">Mar 2021 — Apr 2022</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">KSBS Group Pte Ltd</span>
                <span class="badge-shield-value green">Remote</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Led 3-person team to ship e-commerce platform for 500 concurrent
                users
              </li>
              <li>
                Maintained Django attendance system with 99% production uptime
              </li>
            </ul>
          </div>

          <!-- Hidden older experiences -->
          <div class="experience-item hidden-experience">
            <div class="experience-header">
              <span class="experience-role">Junior Developer</span>
              <span class="experience-period">Jan 2020 — Mar 2021</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">Tech Solutions Ltd</span>
                <span class="badge-shield-value">Pune</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Developed and maintained internal CRUD applications using Python and Django.
              </li>
              <li>
                Optimized SQL queries to improve dashboard load times by 30%.
              </li>
            </ul>
          </div>

          <div class="experience-item hidden-experience">
            <div class="experience-header">
              <span class="experience-role">Software Engineering Intern</span>
              <span class="experience-period">Jun 2019 — Dec 2019</span>
            </div>
            <span class="experience-company">
              <span class="badge-shield">
                <span class="badge-shield-label">Startup Inc</span>
                <span class="badge-shield-value">Pune</span>
              </span>
            </span>
            <ul class="experience-bullets">
              <li>
                Assisted in the migration of monolithic REST APIs to microservices architecture.
              </li>
              <li>
                Wrote comprehensive unit tests, increasing overall code coverage to 85%.
              </li>
            </ul>
          </div>
        </div>

        <div class="show-more-container">
          <button id="show-more-exp" class="btn-secondary">Show older experiences</button>
        </div>
      </section>

      <hr />

      <section class="section">
        <h2>Certifications</h2>
        <div class="cert-grid">
          <div class="cert-card">
            <div class="cert-seal">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7"></circle>
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
              </svg>
            </div>
            <div class="cert-content">
              <span class="cert-name">AWS Machine Learning Specialty (MLS-C01)</span>
              <span class="cert-date">Issued: January 2026</span>
            </div>
          </div>
          <div class="cert-card">
            <div class="cert-seal">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7"></circle>
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
              </svg>
            </div>
            <div class="cert-content">
              <span class="cert-name">AI Agents Fundamentals — Hugging Face</span>
              <span class="cert-date">Issued: March 2026</span>
            </div>
          </div>
        </div>
      </section>

      <hr />

      <section class="section">
        <h2>Currently</h2>
        <p>
          Based in Pune, India. Open to Senior Backend Engineer, Backend Tech
          Lead, and Staff Engineer roles. Remote-first. Open to international
          remote opportunities.
        </p>
        <div class="contact-row">
          <a href={SOCIAL_LINKS.email} class="btn-primary">Email me</a>
          <a
            href={SOCIAL_LINKS.linkedin}
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            LinkedIn
          </a>
          <a
            href={SOCIAL_LINKS.github}
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            GitHub
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-header h1 {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--color-text), var(--color-text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.04em;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .section {
    margin-top: 2.5rem;
  }

  .section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .section p {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    max-width: 620px;
    line-height: 1.75;
  }

  .section strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Project list */
  .project-list {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-list li {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border);
    position: relative;
    transition: all 0.2s ease;
  }
  
  .project-list li:hover {
    border-left-color: var(--color-accent);
    padding-left: 2rem;
  }

  .project-list li a {
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  .project-list li a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    padding-left: 3rem;
  }

  .experience-list::before {
    content: '';
    position: absolute;
    top: 1.5rem;
    bottom: 0;
    left: 1.5rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    border-radius: 2px;
    opacity: 0.5;
  }

  .experience-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: var(--glass-border);
    border-radius: var(--base-radius);
    box-shadow: var(--glass-shadow);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  
  .experience-item::before {
    content: '';
    position: absolute;
    top: 1.75rem; /* Align with header roughly */
    left: calc(-1.5rem - 7px);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 3px solid var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent-glow);
    z-index: 1;
    transition: all 0.3s ease;
  }

  .experience-item::after {
    content: '';
    position: absolute;
    top: 2.15rem;
    left: -1.5rem;
    width: 1.5rem;
    height: 2px;
    background: var(--color-accent);
    opacity: 0.3;
    z-index: 0;
  }

  .experience-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px var(--color-accent-glow);
    border-color: var(--color-border-hover);
  }

  .experience-item:hover::before {
    background: var(--color-accent);
    box-shadow: 0 0 20px var(--color-accent);
    transform: scale(1.2);
  }

  .experience-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .experience-role {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .experience-period {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .experience-company {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .experience-bullets {
    margin-top: 0.5rem;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .experience-bullets li {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Certifications */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .cert-card {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: var(--glass-border);
    border-radius: var(--base-radius);
    box-shadow: var(--glass-shadow);
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: center;
  }

  .cert-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(255, 255, 255, 0.015) 10px,
      rgba(255, 255, 255, 0.015) 20px
    );
    pointer-events: none;
    z-index: 0;
  }

  .cert-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 15px 35px var(--color-accent-glow);
  }

  .cert-seal {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 4px 15px var(--color-accent-glow);
    z-index: 1;
    position: relative;
  }

  .cert-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 1;
    position: relative;
    text-align: left;
  }

  .cert-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
    font-family: var(--font-sans);
  }

  .cert-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }

  /* Show More Button */
  .show-more-container {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    position: relative;
    z-index: 10;
  }

  .hidden-experience {
    display: none;
    opacity: 0;
  }

  .hidden-experience.visible {
    display: flex;
    animation: fadeInDown 0.5s ease forwards;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Contact row */
  .contact-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("show-more-exp");
    const hiddenItems = document.querySelectorAll(".hidden-experience");

    if (btn) {
      btn.addEventListener("click", () => {
        hiddenItems.forEach(item => {
          item.classList.add("visible");
        });
        btn.parentElement?.remove();
      });
    }
  });
</script>
