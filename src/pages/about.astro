---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { aboutCertifications as certs, aboutExperience as experience, aboutFacts as facts, aboutOpenSource as openSource, aboutSocialLinks as socialLinks } from "../data/pages/about";
import "../styles/pages/about.css";
---

<html lang="en">
  <head>
    <BaseHead
      title="About - Rajat Jog"
      description="Senior Backend Engineer from Pune, India. Python, Django, FastAPI. Building systems that last."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="about-hero">
        <div class="hero-copy">
          <span class="page-kicker">About</span>
          <h1>
            Rajat Jog,<br />
            <span>systems over syntax.</span>
          </h1>
          <p>
            Senior backend engineer from Pune, India. Python, Django, FastAPI.
            7+ years building production systems in healthtech and fintech. I
            care about systems that are correct, not just fast.
          </p>
          <p>
            I think in invariants before tables, explicit logic before clever
            abstractions, and idempotency before optimism. I have spent most of
            my career at the intersection of compliance and performance.
          </p>
        </div>

        <aside class="hero-facts">
          {facts.map(([label, value]) => (
            <div class:list={{ highlight: label === "Status" }}>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
          <nav class="hero-links" aria-label="Contact links">
            {socialLinks.map(([label, href]) => (
              <a href={href} target={href.startsWith("mailto") ? undefined : "_blank"} rel="noopener">
                {label}
              </a>
            ))}
          </nav>
        </aside>
      </section>

      <section class="about-section">
        <div class="section-title split">
          <div>
            <span>02</span>
            <h2>Experience</h2>
          </div>
          <p>{experience.length} roles / 7+ years</p>
        </div>

        <div class="experience-list" id="experienceList">
          {experience.map((job, index) => (
            <article class:list={["experience-row", { hidden: index >= 3 }]}>
              <div class="experience-meta">
                <span>{job.period}</span>
                <strong>{job.company}</strong>
                <small>{job.location}</small>
              </div>

              <div class="timeline-rail">
                <span class:list={["timeline-dot", { current: job.current }]}></span>
                {index < experience.length - 1 && <i></i>}
              </div>

              <div class:list={["experience-card", { current: job.current }]}>
                {job.current && <div class="current-line"></div>}
                <div class="experience-head">
                  <h3>{job.role}</h3>
                  {job.current && <span>Current</span>}
                </div>
                <ul>
                  {job.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
                <div class="tag-row">
                  {job.tags.map((tag) => <span class="chip">{tag}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="show-more-wrap">
          <button class="show-more" id="showMoreExperience" type="button">
            <span>Show 1 more</span>
            <i>v</i>
          </button>
          <small id="experienceCount">3 of {experience.length}</small>
        </div>
      </section>

      <section class="about-section">
        <div class="section-title">
          <span>03</span>
          <h2>Certifications</h2>
        </div>

        <div class="cert-grid">
          {certs.map((cert) => (
            <article class:list={["cert-card", cert.accent]}>
              <div>
                <span>{cert.org}</span>
                <h3>{cert.name}</h3>
                <p>Issued {cert.issued}</p>
              </div>
              <div class="cert-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="about-section">
        <div class="section-title">
          <span>04</span>
          <h2>Open Source</h2>
        </div>

        <div class="oss-list">
          {openSource.map((project) => (
            <a href={project.href} target="_blank" rel="noopener" class="oss-row">
              <strong>{project.name}</strong>
              <span>{project.description}</span>
              <i>{project.linkText}</i>
            </a>
          ))}
        </div>
      </section>

      <section class="about-cta">
        <div>
          <span class="page-kicker">Open to Senior Backend Roles</span>
          <h2>Let's build something that lasts.</h2>
        </div>
        <a href="/rajatjog-website/contact" class="btn-primary">Get in touch -&gt;</a>
      </section>
    </main>

    <Footer />

    <script>import "../scripts/about-experience";</script>
  </body>
</html>
