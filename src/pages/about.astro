---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SOCIAL_LINKS } from "../consts";

const projects = [
  ["timeblocks", "Recurring time availability scheduling for Django.", "https://pypi.org/project/timeblocks/"],
  ["django-system-audit", "Intent-aware audit trails for Django and DRF.", "https://pypi.org/project/django-system-audit/"],
  ["django-ml-audit", "Per-prediction ML audit trails for Django production systems.", "https://pypi.org/project/django-ml-audit/"],
];

const experience = [
  {
    role: "Senior Software Engineer",
    period: "Feb 2024 - Present",
    company: "Mindbowser Inc",
    bullets: [
      "Integrated production ML workflows using AWS SageMaker for predictive healthcare analytics.",
      "Engineered HIPAA and SOC2-compliant platforms using HL7 and FHIR protocols.",
      "Led 5+ engineers, reduced production bugs 25%, accelerated delivery by 6 weeks.",
    ],
  },
  {
    role: "Software Engineer",
    period: "Nov 2022 - Feb 2024",
    company: "Mindbowser Inc",
    bullets: [
      "Reduced API latency 60% via PostgreSQL indexing and Redis caching.",
      "Architected Django and FastAPI backends for 5k DAU, 300 RPM healthcare platforms.",
    ],
  },
  {
    role: "Software Engineer",
    period: "Apr 2022 - Nov 2022",
    company: "KiwiTech",
    bullets: [
      "Scaled RESTful APIs for 7+ clients handling 5-7 GB daily data throughput.",
      "Built Celery task queues for 15+ daily background jobs with zero missed deliveries.",
    ],
  },
  {
    role: "Python Developer",
    period: "Mar 2021 - Apr 2022",
    company: "KSBS Group Pte Ltd",
    bullets: [
      "Led a 3-person team to ship an e-commerce platform for 500 concurrent users.",
      "Maintained a Django attendance system with 99% production uptime.",
    ],
  },
];
---

<html lang="en">
  <head>
    <BaseHead
      title="About - Rajat Jog"
      description="Senior Backend Engineer from Pune, India. Python, Django, FastAPI. Building systems that last."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <span class="page-kicker">About</span>
        <h1>
          Rajat Jog,<br />
          <span>systems over syntax.</span>
        </h1>
        <p class="page-subtitle">
          Senior Backend Engineer from Pune, India. Python, Django, FastAPI.
          Remote-first.
        </p>
      </section>

      <section class="about-grid">
        <div class="prose intro-copy">
          <p>
            I'm Rajat - a senior backend engineer with 7+ years building
            production systems in healthtech and fintech. I care about systems
            that are correct, not just fast.
          </p>
          <p>
            Good engineering is not about knowing more frameworks. It is about
            understanding what you are building and why. I think in invariants
            before tables, explicit logic before clever abstractions, and
            idempotency before optimism.
          </p>
          <p>
            I have spent most of my career at the intersection of compliance and
            performance - building HIPAA and SOC2-compliant platforms where "it
            works" is not enough if it is not auditable.
          </p>
        </div>

        <aside class="fact-panel">
          {[
            ["Location", "Pune, India"],
            ["Experience", "7+ years"],
            ["Domains", "Healthtech / Fintech"],
            ["Stack", "Python / Django / FastAPI"],
          ].map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </aside>
      </section>

      <section class="section-block">
        <div class="section-title">
          <span>01</span>
          <h2>What I have built</h2>
        </div>
        <div class="project-grid">
          {projects.map(([name, description, href]) => (
            <a href={href} target="_blank" rel="noopener" class="mini-card">
              <h3>{name}</h3>
              <p>{description}</p>
              <span>PyPI -></span>
            </a>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-title">
          <span>02</span>
          <h2>Experience</h2>
        </div>
        <div class="timeline">
          {experience.map((item) => (
            <article class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-card">
                <div class="timeline-head">
                  <h3>{item.role}</h3>
                  <span>{item.period}</span>
                </div>
                <span class="badge-shield">
                  <span class="badge-shield-label">{item.company}</span>
                  <span class="badge-shield-value green">Remote</span>
                </span>
                <ul>
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-title">
          <span>03</span>
          <h2>Certifications</h2>
        </div>
        <div class="cert-grid">
          <div class="cert-card">
            <span>AWS</span>
            <strong>AWS Machine Learning Specialty (MLS-C01)</strong>
            <p>Issued: January 2026</p>
          </div>
          <div class="cert-card teal">
            <span>AI</span>
            <strong>AI Agents Fundamentals - Hugging Face</strong>
            <p>Issued: March 2026</p>
          </div>
        </div>
      </section>

      <section class="section-block cta-block">
        <div>
          <span class="page-kicker">Currently</span>
          <h2>Open to senior backend roles.</h2>
          <p>
            Senior Backend Engineer, Backend Tech Lead, or Staff Engineer roles.
            Remote-first, open to international remote.
          </p>
        </div>
        <div class="cta-actions">
          <a href={SOCIAL_LINKS.email} class="btn-primary">Email me</a>
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" class="btn-secondary">LinkedIn</a>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" class="btn-secondary">GitHub</a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-header h1 span {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .about-grid {
    display: grid;
    gap: 5rem;
    grid-template-columns: minmax(0, 1fr) 320px;
  }

  .fact-panel {
    border-top: 1px solid var(--color-border);
  }

  .fact-panel div {
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 0;
  }

  .fact-panel span,
  .section-title span,
  .mini-card span,
  .timeline-head span,
  .cert-card span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .fact-panel strong {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 400;
  }

  .section-block {
    border-top: 1px solid var(--color-border);
    margin-top: 5rem;
    padding-top: 4rem;
  }

  .section-title {
    align-items: baseline;
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-title h2 {
    font-size: 1.6rem;
    font-weight: 400;
  }

  .project-grid,
  .cert-grid {
    display: grid;
    gap: 2px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .mini-card,
  .cert-card {
    border: 1px solid var(--color-border);
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
  }

  .mini-card:hover,
  .cert-card:hover,
  .timeline-card:hover {
    background: var(--color-bg-secondary);
    color: inherit;
  }

  .mini-card h3 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 400;
  }

  .mini-card p,
  .cert-card p {
    font-size: 0.88rem;
    margin: 0;
  }

  .mini-card span {
    color: var(--color-accent);
    margin-top: auto;
  }

  .timeline {
    border-left: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-left: 0.5rem;
    padding-left: 2rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    border-radius: 999px;
    height: 14px;
    left: calc(-2rem - 7px);
    position: absolute;
    top: 1.55rem;
    width: 14px;
  }

  .timeline-card {
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .timeline-head {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .timeline-head h3 {
    font-size: 1rem;
    font-weight: 500;
  }

  .timeline ul {
    margin: 1rem 0 0 1rem;
  }

  .timeline li {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 0.4rem;
  }

  .timeline li::marker {
    color: var(--color-accent);
  }

  .cert-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cert-card {
    border-top: 2px solid var(--color-accent);
  }

  .cert-card.teal {
    border-top-color: var(--color-teal);
  }

  .cert-card strong {
    font-size: 1rem;
    font-weight: 500;
  }

  .cta-block {
    align-items: center;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
  }

  .cta-block h2 {
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .cta-block p {
    margin: 0;
    max-width: 560px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 860px) {
    .about-grid,
    .project-grid,
    .cert-grid {
      grid-template-columns: 1fr;
    }

    .cta-block {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
