---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SOCIAL_LINKS } from "../consts";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    title: "django-system-audit",
    badgeLabel: "PyPI",
    badgeClass: "badge badge-pypi",
    why: "Signals capture effects. Compliance systems need to capture intent.",
    description:
      "Intent-aware audit trail library for Django and DRF. Built for HIPAA and SOC2 environments where audit logs must be legally defensible.",
    stack: ["Python", "Django", "DRF"],
    links: [
      { label: "PyPI", href: "https://pypi.org/project/django-system-audit/" },
      {
        label: "GitHub",
        href: "https://github.com/RJ-Gamer/django-system-audit",
      },
    ],
  },
  {
    title: "timeblocks",
    badgeLabel: "PyPI",
    badgeClass: "badge badge-pypi",
    why: "Healthcare scheduling fails because availability is modelled as mutable state, not invariants.",
    description:
      "Recurring time availability scheduling for Django. Concurrency-safe — changing availability never corrupts booked records.",
    stack: ["Python", "Django"],
    links: [
      { label: "PyPI", href: "https://pypi.org/project/timeblocks/" },
      { label: "GitHub", href: "https://github.com/RJ-Gamer/timeblocks" },
    ],
  },
];
---

<html lang="en">
  <head>
    <BaseHead
      title="Rajat Jog — Senior Backend Engineer"
      description={SITE_DESCRIPTION}
    />
  </head>
  <body style="min-height: 100vh; display: flex; flex-direction: column;">
    <Header />

    <main style="flex: 1;">
      <!-- Hero -->

      <section class="hero">
        <p class="hero-eyebrow">Senior Backend Engineer</p>
        <h1 class="hero-name">Rajat Jog</h1>
        <p class="hero-stack">
          Python · Django · FastAPI ·
          <span class="typewriter" id="typewriter"></span>
        </p>
        <p class="hero-tagline">
          I build backend systems that are meant to last — not just work.
        </p>
        <div class="hero-actions">
          <a href="/rajatjog-website/projects" class="btn-primary"
            >View my work</a
          >
          <a href="/rajatjog-website/blog" class="btn-secondary"
            >Read my writing</a
          >
        </div>
      </section>

      <!-- Skills -->
      <section class="section">
        <p class="section-heading">Skills & Stack</p>
        <div class="skills-grid">
          <div class="skill-group">
            <p class="skill-group-label">Backend</p>
            <div class="skill-tags">
              <span class="skill-tag expert">Python</span>
              <span class="skill-tag expert">Django</span>
              <span class="skill-tag expert">FastAPI</span>
              <span class="skill-tag expert">Django REST Framework</span>
              <span class="skill-tag expert">Celery</span>
              <span class="skill-tag expert">Redis</span>
            </div>
          </div>

          <div class="skill-group">
            <p class="skill-group-label">Database</p>
            <div class="skill-tags">
              <span class="skill-tag expert">PostgreSQL</span>
              <span class="skill-tag mid">Query Optimisation</span>
              <span class="skill-tag mid">Database Indexing</span>
              <span class="skill-tag mid">Schema Design</span>
            </div>
          </div>

          <div class="skill-group">
            <p class="skill-group-label">Cloud & Infra</p>
            <div class="skill-tags">
              <span class="skill-tag mid">AWS</span>
              <span class="skill-tag mid">SageMaker</span>
              <span class="skill-tag mid">Lambda</span>
              <span class="skill-tag mid">S3</span>
              <span class="skill-tag mid">Docker</span>
              <span class="skill-tag mid">Railway</span>
            </div>
          </div>

          <div class="skill-group">
            <p class="skill-group-label">Domains</p>
            <div class="skill-tags">
              <span class="skill-tag domain">HIPAA</span>
              <span class="skill-tag domain">SOC2</span>
              <span class="skill-tag domain">HL7/FHIR</span>
              <span class="skill-tag domain">Healthtech</span>
              <span class="skill-tag domain">Fintech</span>
            </div>
          </div>

          <div class="skill-group">
            <p class="skill-group-label">Currently Learning</p>
            <div class="skill-tags">
              <span class="skill-tag learning">System Design</span>
              <span class="skill-tag learning">DSA</span>
              <span class="skill-tag learning">AI Agents</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Featured Projects -->
      <section class="section">
        <p class="section-heading">Featured Projects</p>
        <div class="project-grid">
          {
            projects.map((project) => (
              <div class="card project-card">
                <div class="project-card-top">
                  <div class="project-title-row">
                    <h3 class="project-title">{project.title}</h3>
                    <span class={project.badgeClass}>{project.badgeLabel}</span>
                  </div>
                  <p class="project-why">"{project.why}"</p>
                  <p class="project-description">{project.description}</p>
                </div>
                <div class="project-card-bottom">
                  <div class="project-stack">
                    {project.stack.map((tag) => (
                      <span class="badge">{tag}</span>
                    ))}
                  </div>
                  <div class="project-links">
                    {project.links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener"
                        class="project-link"
                      >
                        {link.label} →
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
        <div class="view-all">
          <a href="/rajatjog-website/projects" class="btn-secondary"
            >View all projects</a
          >
        </div>
      </section>

      <!-- Latest Writing -->
      <section class="section">
        <p class="section-heading">Latest Writing</p>
        {
          posts.length === 0 ? (
            <div class="empty-state">
              <p>Posts coming soon.</p>
              <p>
                In the meantime, I write regularly on
                <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">
                  LinkedIn
                </a>
                about Django system design and backend engineering.
              </p>
            </div>
          ) : (
            <div class="post-list">
              {posts.map((post) => (
                <a href={`/rajatjog-website/blog/${post.id}/`} class="post-row">
                  <div class="post-row-left">
                    <span class="post-title">{post.data.title}</span>
                    <span class="post-description">
                      {post.data.description}
                    </span>
                  </div>
                  <span class="post-date">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </span>
                </a>
              ))}
            </div>
          )
        }
        <div class="view-all">
          <a href="/rajatjog-website/blog" class="btn-secondary"
            >View all posts</a
          >
        </div>
      </section>

      <!-- About -->
      <section class="section about-blurb">
        <p class="section-heading">About</p>
        <p>
          I'm a senior backend engineer from Pune, India specialising in Python,
          Django, and FastAPI. I've spent 7+ years building production systems
          in healthtech and fintech — the kind that need to be correct, not just
          fast.
        </p>
        <p>
          I open-source the hard parts. My libraries
          <a
            href="https://pypi.org/project/timeblocks/"
            target="_blank"
            rel="noopener">timeblocks</a
          >,
          <a
            href="https://pypi.org/project/django-system-audit/"
            target="_blank"
            rel="noopener">django-system-audit</a
          >, and
          <a
            href="https://pypi.org/project/django-ml-audit/"
            target="_blank"
            rel="noopener">django-ml-audit</a
          >
          exist because I kept hitting the same architectural problems in production
          and decided to solve them properly once.
        </p>
        <div class="view-all">
          <a href="/rajatjog-website/contact" class="btn-secondary"
            >Get in touch</a
          >
        </div>
      </section>
    </main>

    <Footer />
  </body><script>
    const words = [
      "AWS ML Certified",
      "Open Source Author",
      "Backend Architect",
      "Systems Thinker",
      "HIPAA/SOC2 Expert",
      "API Designer",
    ];

    let wordIndex = 0;
    let charIndex = 0;
    let deleting = false;
    const el = document.getElementById("typewriter");
    const typeSpeed = 80;
    const deleteSpeed = 40;
    const pauseTime = 1800;

    function type() {
      if (!el) return;

      const current = words[wordIndex];

      if (!deleting) {
        el.textContent = current.slice(0, charIndex + 1);
        charIndex++;

        if (charIndex === current.length) {
          deleting = true;
          setTimeout(type, pauseTime);
          return;
        }
      } else {
        el.textContent = current.slice(0, charIndex - 1);
        charIndex--;

        if (charIndex === 0) {
          deleting = false;
          wordIndex = (wordIndex + 1) % words.length;
        }
      }

      setTimeout(type, deleting ? deleteSpeed : typeSpeed);
    }

    type();
  </script>
</html>

<style>
  .hero {
    padding: 3.5rem 0 1rem;
    position: relative;
    isolation: isolate;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -2rem;
    left: -50vw;
    right: -50vw;
    bottom: 0;
    background-image: radial-gradient(
      circle,
      var(--color-border) 1.5px,
      transparent 1.5px
    );
    background-size: 28px 28px;
    opacity: 0.5;
    z-index: -1;
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
  }

  .hero-name {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .hero-stack {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .project-why {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  .project-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .project-card-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent) !important;
    text-decoration: none;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .post-row:last-child {
    border-bottom: none;
  }

  .post-row:hover {
    background: var(--color-bg-secondary);
  }

  .post-row-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .post-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .empty-state {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .empty-state p:last-child {
    margin-bottom: 0;
  }

  .about-blurb p {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    max-width: 620px;
  }

  .view-all {
    margin-top: 1.5rem;
  }

  @media (max-width: 640px) {
    .hero-name {
      font-size: 2.25rem;
    }
    .hero-tagline {
      font-size: 1.05rem;
    }
    .post-row {
      flex-direction: column;
      gap: 0.25rem;
    }
    .post-date {
      font-size: 0.75rem;
    }
  }

  /* Typewriter */
  .typewriter {
    color: var(--color-accent);
    font-weight: 500;
    border-right: 2px solid var(--color-accent);
    padding-right: 3px;
    white-space: nowrap;
    animation: blink 0.7s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      border-color: var(--color-accent);
    }
    50% {
      border-color: transparent;
    }
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 0.75rem;
    align-items: start;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .skill-group:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .skill-group-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
    margin: 0;
    padding-top: 0.2rem;
  }

  .skill-tag {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 4px;
    border: 1px solid transparent;
    letter-spacing: 0.01em;
  }

  .skill-tag.expert {
    background: var(--color-accent);
    color: #ffffff;
    border-color: var(--color-accent);
  }

  .skill-tag.mid {
    background: transparent;
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .skill-tag.domain {
    background: var(--color-badge);
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .skill-tag.learning {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px dashed var(--color-border);
  }
  @media (max-width: 640px) {
    .skill-group {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
