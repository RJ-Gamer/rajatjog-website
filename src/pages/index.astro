---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SOCIAL_LINKS, SITE_URL } from "../consts";
import { homeCoreStack, homeProjects as projects, homeSkills as skills, homeStats as stats } from "../data/pages/home";
import "../styles/pages/home.css";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<html lang="en">
  <head>
    <BaseHead
      title="Rajat Jog - Senior Backend Engineer"
      description={SITE_DESCRIPTION}
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Rajat Jog",
      url: SITE_URL,
      jobTitle: "Senior Backend Engineer",
      sameAs: [
        "https://github.com/RJ-Gamer",
        "https://linkedin.com/in/rajat-jog",
      ],
    })} />
  </head>
  <body>
    <Header />

    <main>
      <section class="hero">
        <div class="status-line">
          <span class="status-dot"></span>
          <span>Open to Senior Backend Roles</span>
        </div>

        <h1>
          Building systems<br />
          <span>that last.</span>
        </h1>

        <p class="hero-copy">
          I'm <strong>Rajat Jog</strong> - a Senior Backend Engineer specialising
          in scalable, resilient backend architectures. Correctness and
          performance are non-negotiable.
        </p>

        <div class="stack-list" aria-label="Core stack">
          {homeCoreStack.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
        </div>

        <div class="hero-actions">
          <a href="/projects" class="btn-primary">View my work</a>
          <a href="/contact" class="btn-secondary">Get in touch</a>
          <div class="hero-social">
            <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub</a>
            <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            <a href={SOCIAL_LINKS.pypi} target="_blank" rel="noopener">PyPI</a>
          </div>
        </div>

        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat">
              <div class:list={["stat-value", { stacked: stat.stacked }]}>
                {stat.value}
                <span>{stat.unit}</span>
              </div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="panel-section">
        <div class="section-title">
          <span>02 / Stack</span>
          <h2>Skills & Tooling</h2>
        </div>
        <div class="skills-list">
          {skills.map((row) => (
            <div class="skill-row">
              <div class="skill-label">{row.category}</div>
              <div class="skill-tags">
                {row.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="panel-section" id="projects">
        <div class="section-title">
          <span>03 / Work</span>
          <h2>Projects</h2>
        </div>
        <div class="project-grid">
          {projects.map((project) => (
            <article class:list={["feature-card", project.accent]}>
              <div class="card-line"></div>
              <p class="card-meta">{project.meta}</p>
              <h3>{project.name}</h3>
              {project.quote && <blockquote>{project.quote}</blockquote>}
              <p>{project.description}</p>
              <div class="tag-row">
                {project.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
              {project.links.length > 0 && (
                <div class="card-links">
                  {project.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener">{link.label} -></a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
        <a href="/projects" class="text-link">All projects -></a>
      </section>

      <section class="panel-section" id="blog">
        <div class="section-title section-title-split">
          <div>
            <span>04 / Writing</span>
            <h2>Blog</h2>
          </div>
          <a href="/blog">All posts -></a>
        </div>
        <p class="section-intro">System design, Django internals, and lessons from production.</p>

        {posts.length === 0 ? (
          <div class="empty-state">Posts coming soon.</div>
        ) : (
          <div class="writing-grid">
            {posts.map((post, index) => (
              <a
                href={`/blog/${post.id}/`}
                class:list={["post-card", { featured: index === 0 }]}
              >
                <div class="post-meta">
                  {index === 0 && <span class="featured-label">Featured</span>}
                  <span>
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.tags && (
                  <div class="tag-row">
                    {post.data.tags.map((tag: string) => <span class="chip">{tag}</span>)}
                  </div>
                )}
                <span class="read-link">Read post -></span>
              </a>
            ))}
          </div>
        )}
      </section>

      <section class="panel-section about-contact">
        <div>
          <div class="section-title">
            <span>05 / About</span>
            <h2>Rajat Jog</h2>
          </div>
          <p>
            Senior backend engineer from Pune, India specialising in Python,
            Django, and FastAPI. 7+ years building production systems across
            fintech, SaaS, and internal platforms - the kind that need to be
            correct, not just fast.
          </p>
          <p>
            I open-source the hard parts. timeblocks, django-system-audit, and
            django-ml-audit exist because I kept hitting the same architectural
            problems in production and decided to solve them properly once.
          </p>
        </div>
        <div class="contact-panel">
          {[
            ["Location", "Pune, India", ""],
            ["GitHub", "@RJ-Gamer", SOCIAL_LINKS.github],
            ["LinkedIn", "rajat-jog", SOCIAL_LINKS.linkedin],
            ["PyPI", "rajatjog1294", SOCIAL_LINKS.pypi],
            ["Email", "rajatjog1294@gmail.com", SOCIAL_LINKS.email],
          ].map(([label, value, href]) => (
            <div class="contact-row">
              <span>{label}</span>
              {href ? (
                <a href={href} target={href.startsWith("mailto") ? undefined : "_blank"} rel="noopener">{value}</a>
              ) : (
                <strong>{value}</strong>
              )}
            </div>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
