---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";

const rawPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = rawPosts.map((post, index) => {
  const words = post.body?.trim().split(/\s+/).filter(Boolean).length ?? 1200;
  return {
    ...post,
    num: String(index + 1).padStart(2, "0"),
    readTime: Math.max(1, Math.ceil(words / 220)),
  };
});

const allTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];
const totalMinutes = posts.reduce((total, post) => total + post.readTime, 0);
const featured = posts[0];
const listPosts = posts.slice(1);
---

<html lang="en">
  <head>
    <BaseHead
      title="Writing - Rajat Jog"
      description="Thoughts on Django, system design, open source, and backend engineering."
    />
  </head>
  <body>
    <Header />

    <main class="journal-main">
      <section class="journal-masthead">
        <div class="masthead-copy">
          <span class="page-kicker">Writing</span>
          <h1>
            The<br />
            <span>journal.</span>
          </h1>
        </div>

        <div class="masthead-side">
          <p>
            System design, Django internals, and the honest story of shipping
            things - open source and otherwise.
          </p>
          <div class="masthead-stats">
            {[
              [posts.length, "Articles"],
              [`${totalMinutes} min`, "Total read"],
              [allTags.length, "Topics"],
            ].map(([value, label]) => (
              <div>
                <strong>{value}</strong>
                <span>{label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p>Posts coming soon.</p>
          <p>
            In the meantime, I write regularly on
            <a href="https://linkedin.com/in/rajat-jog" target="_blank" rel="noopener"> LinkedIn</a>
            about Django system design and backend engineering.
          </p>
        </div>
      ) : (
        <>
          <section class="featured-hero">
            <a href={`/rajatjog-website/blog/${featured.id}/`} class="featured-link">
              <div class="featured-title">
                <div class="article-meta">
                  <span class="latest-label">Latest</span>
                  <time datetime={featured.data.pubDate.toISOString()}>
                    {featured.data.pubDate.toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </time>
                  <span>/ {featured.readTime} min read</span>
                </div>
                <h2>{featured.data.title}</h2>
                <div class="hover-line"></div>
              </div>

              <div class="featured-summary">
                <p>{featured.data.description}</p>
                {featured.data.tags && (
                  <div class="tag-row">
                    {featured.data.tags.map((tag: string) => <span class="chip">{tag}</span>)}
                  </div>
                )}
                <span class="article-cta">
                  Read article
                  <i>-&gt;</i>
                </span>
              </div>
            </a>
          </section>

          <section class="archive-section">
            <div class="archive-head">
              <div class="tag-filter" aria-label="Writing topics">
                <button class="chip active" data-tag="all">All ({posts.length})</button>
                {allTags.map((tag) => (
                  <button class="chip" data-tag={tag}>{tag}</button>
                ))}
              </div>
              <span class="archive-count">{posts.length} articles</span>
            </div>

            {listPosts.length > 0 ? (
              <div class="post-list">
                {listPosts.map((post) => (
                  <a href={`/rajatjog-website/blog/${post.id}/`} class="post-row" data-tags={JSON.stringify(post.data.tags ?? [])}>
                    <span class="post-num">{post.num}</span>
                    <div class="post-title-block">
                      <h3>{post.data.title}</h3>
                      {post.data.tags && (
                        <div class="tag-row compact">
                          {post.data.tags.map((tag: string) => <span class="chip">{tag}</span>)}
                        </div>
                      )}
                    </div>
                    <p>{post.data.description}</p>
                    <div class="post-side">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </time>
                      <span>{post.readTime} min read</span>
                      <i>-&gt;</i>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="single-note">More articles coming soon.</div>
            )}
          </section>

          <section class="follow-strip">
            <div>
              <h2>Want to follow along?</h2>
              <p>New articles on Django, system design, and building in public.</p>
            </div>
            <div class="follow-links">
              <a href="https://github.com/RJ-Gamer" target="_blank" rel="noopener">GitHub</a>
              <a href="https://linkedin.com/in/rajat-jog" target="_blank" rel="noopener">LinkedIn</a>
            </div>
          </section>
        </>
      )}
    </main>

    <Footer />
  </body>
</html>

<style>
  .journal-main {
    max-width: 1200px;
  }

  .journal-masthead {
    align-items: end;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    gap: 4rem;
    grid-template-columns: minmax(0, 1fr) 380px;
    padding-bottom: 4rem;
  }

  .journal-masthead h1 {
    font-size: clamp(4rem, 9vw, 7.2rem);
    letter-spacing: 0;
    line-height: 0.95;
    margin: 0;
  }

  .journal-masthead h1 span {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .masthead-side p {
    font-size: 0.95rem;
    margin-bottom: 2.2rem;
  }

  .masthead-stats {
    display: flex;
    gap: 2rem;
  }

  .masthead-stats div,
  .post-side,
  .follow-strip div:first-child {
    min-width: 0;
  }

  .masthead-stats strong {
    color: var(--color-text);
    display: block;
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 300;
    margin-bottom: 0.2rem;
  }

  .masthead-stats span,
  .archive-count,
  .post-side time,
  .post-side span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-hero {
    border-bottom: 1px solid var(--color-border);
  }

  .featured-link {
    color: inherit;
    display: grid;
    gap: 5rem;
    grid-template-columns: minmax(0, 1fr) 420px;
    padding: 5rem 0 4.5rem;
  }

  .featured-link:hover {
    color: inherit;
  }

  .article-meta {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .latest-label {
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent-border);
    border-radius: 3px;
    color: var(--color-accent);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.6rem;
    text-transform: uppercase;
  }

  .featured-title h2 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.08;
    max-width: 680px;
  }

  .hover-line {
    background: linear-gradient(90deg, var(--color-accent), transparent);
    height: 1px;
    margin-top: 1.4rem;
    transition: width 0.35s ease;
    width: 0;
  }

  .featured-link:hover .hover-line {
    width: 100%;
  }

  .featured-summary {
    align-self: end;
  }

  .featured-summary p {
    font-size: 0.95rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tag-row.compact .chip {
    font-size: 0.62rem;
    padding: 0.18rem 0.48rem;
  }

  .chip.active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent-border);
    color: var(--color-accent);
  }

  .article-cta {
    align-items: center;
    color: var(--color-text-secondary);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .article-cta i,
  .post-side i {
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    display: inline-flex;
    font-style: normal;
    height: 32px;
    justify-content: center;
    transition: border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
    width: 32px;
  }

  .featured-link:hover .article-cta,
  .featured-link:hover .article-cta i,
  .post-row:hover .post-side i {
    border-color: var(--color-accent-border);
    color: var(--color-accent);
  }

  .featured-link:hover .article-cta i,
  .post-row:hover .post-side i {
    transform: translate(3px, -3px);
  }

  .archive-section {
    padding-top: 3rem;
  }

  .archive-head {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-filter .chip {
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .tag-filter .chip:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .tag-filter .chip.active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent-border);
    color: var(--color-accent);
  }

  .post-list {
    border-top: 1px solid var(--color-border);
  }

  .post-row {
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    color: inherit;
    display: grid;
    gap: 2rem;
    grid-template-columns: 72px minmax(220px, 1fr) minmax(220px, 300px) 120px;
    padding: 2.25rem 1.5rem;
  }

  .post-row:hover {
    background: var(--color-bg-secondary);
    color: inherit;
  }

  .post-num {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 300;
    letter-spacing: 0;
    transition: color 0.18s ease;
  }

  .post-row:hover .post-num {
    color: var(--color-accent);
  }

  .post-title-block h3 {
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 0.7rem;
  }

  .post-row p {
    display: -webkit-box;
    font-size: 0.84rem;
    line-height: 1.65;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .post-side {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: right;
  }

  .post-side i {
    margin-left: auto;
    margin-top: 0.7rem;
  }

  .single-note,
  .empty-state {
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 2rem;
  }

  .follow-strip {
    align-items: center;
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    margin-top: 1rem;
    padding: 4.5rem 0 2rem;
  }

  .follow-strip h2 {
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.4rem;
  }

  .follow-strip p {
    font-size: 0.9rem;
    margin: 0;
  }

  .follow-links {
    display: flex;
    gap: 0.75rem;
  }

  .follow-links a {
    border: 1px solid var(--color-border);
    border-radius: var(--base-radius);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    padding: 0.7rem 1.25rem;
  }

  .follow-links a:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  @media (max-width: 980px) {
    .journal-masthead,
    .featured-link,
    .post-row {
      grid-template-columns: 1fr;
    }

    .journal-masthead,
    .featured-link {
      gap: 3rem;
    }

    .post-row {
      align-items: start;
      gap: 1rem;
      padding: 2rem 0;
    }

    .post-side {
      text-align: left;
    }

    .post-side i {
      margin-left: 0;
    }
  }

  @media (max-width: 640px) {
    .journal-masthead h1 {
      font-size: 4rem;
    }

    .masthead-stats,
    .follow-strip,
    .follow-links {
      align-items: flex-start;
      flex-direction: column;
    }

    .featured-link {
      padding: 3.5rem 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.tag-filter .chip');
    const postRows = document.querySelectorAll('.post-row');
    const archiveCount = document.querySelector('.archive-count');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const selectedTag = button.dataset.tag;
        
        // Update active state
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter posts
        let visibleCount = 0;
        postRows.forEach(row => {
          const tags = JSON.parse(row.dataset.tags || '[]');
          if (selectedTag === 'all' || tags.includes(selectedTag)) {
            row.style.display = '';
            visibleCount++;
          } else {
            row.style.display = 'none';
          }
        });

        // Update count
        if (archiveCount) {
          archiveCount.textContent = `${visibleCount} article${visibleCount !== 1 ? 's' : ''}`;
        }
      });
    });
  });
</script>
