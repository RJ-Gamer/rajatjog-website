---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="en">
  <head>
    <BaseHead
      title="Writing — Rajat Jog"
      description="Thoughts on Django, system design, open source, and backend engineering."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-header">
        <h1>Writing</h1>
        <p class="page-subtitle">
          System design, Django internals, and lessons from production.
        </p>
      </section>

      <hr />

      {
        posts.length === 0 ? (
          <div class="empty-state">
            <p>Posts coming soon.</p>
            <p>
              In the meantime, I write regularly on
              <a
                href="https://linkedin.com/in/rajat-jog"
                target="_blank"
                rel="noopener"
              >
                LinkedIn
              </a>
              about Django system design and backend engineering.
            </p>
          </div>
        ) : (
          <div class="post-list">
            {posts.map((post) => (
              <a href={`/rajatjog-website/blog/${post.id}/`} class="post-row">
                <div class="post-left">
                  <span class="post-title">{post.data.title}</span>
                  <span class="post-description">{post.data.description}</span>
                  {post.data.tags && (
                    <div class="post-tags">
                      {post.data.tags.map((tag: string) => (
                        <span class="badge">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </span>
              </a>
            ))}
          </div>
        )
      }
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .empty-state {
    margin-top: 2.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .empty-state p:last-child {
    margin-bottom: 0;
  }

  .post-list {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .post-row:last-child {
    border-bottom: none;
  }

  .post-row:hover {
    background: var(--color-bg-secondary);
  }

  .post-left {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
  }

  .post-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  @media (max-width: 640px) {
    .post-row {
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-date {
      font-size: 0.75rem;
    }
  }
</style>
