---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_URL } from "../consts";
import "../styles/pages/blog-post.css";

type SuggestedPost = CollectionEntry<"blog">;
type Props = CollectionEntry<"blog">["data"] & {
  suggestedPosts?: SuggestedPost[];
};
const { title, description, pubDate, updatedDate, tags, suggestedPosts = [] } = Astro.props;
const slug = Astro.url.pathname.split("/").filter(Boolean).pop();
const ogImage = `/og/${slug}.png`;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const formattedUpdated = updatedDate?.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage} type="article" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      author: { "@type": "Person", name: "Rajat Jog", url: SITE_URL },
      image: new URL(ogImage, Astro.site).toString(),
      url: Astro.url.toString(),
    })} />
  </head>
  <body>
    <Header />
    <div class="reading-progress" id="readingProgress"></div>

    <main class="article-shell">
      <a href="/blog" class="back-link">&lt;- All posts</a>

      <article class="post" id="article">
        <header class="post-header page-header">
          <span class="page-kicker">Writing</span>
          {tags && tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag: string) => <span class="chip active">{tag}</span>)}
            </div>
          )}
          <h1>{title}</h1>
          <p class="post-description page-subtitle">{description}</p>
          <div class="post-meta">
            <div class="author-mark">RJ</div>
            <div>
              <strong>Rajat Jog</strong>
              <span>Senior Backend Engineer</span>
            </div>
            <i></i>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {formattedUpdated && <span>Updated {formattedUpdated}</span>}
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        <footer class="author-card">
          <div class="author-mark large">RJ</div>
          <div>
            <h2>Rajat Jog</h2>
            <p>
              Senior Backend Engineer from Pune, India. Specialises in Python,
              Django, and FastAPI. Builds reliable production systems and
              open-sources the hard parts.
            </p>
            <div class="author-links">
              <a href="https://linkedin.com/in/rajat-jog" target="_blank" rel="noopener">LinkedIn -></a>
              <a href="https://github.com/RJ-Gamer" target="_blank" rel="noopener">GitHub -></a>
              <a href="https://pypi.org/user/rajatjog1294" target="_blank" rel="noopener">PyPI -></a>
            </div>
          </div>
        </footer>

        {suggestedPosts.length > 0 && (
          <section class="suggested-posts" aria-labelledby="suggested-posts-heading">
            <div class="suggested-head">
              <span class="page-kicker">More Writing</span>
              <h2 id="suggested-posts-heading">Suggested blogs</h2>
            </div>
            <div class="suggested-grid">
              {suggestedPosts.map((post) => (
                <a href={`/blog/${post.id}/`} class="suggested-card">
                  <div class="suggested-copy">
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="tag-row">
                        {post.data.tags.slice(0, 3).map((tag: string) => <span class="chip">{tag}</span>)}
                      </div>
                    )}
                  </div>
                  <div class="suggested-side">
                    <div class="suggested-meta">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </time>
                    </div>
                    <span class="suggested-link">Read post -&gt;</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <div class="post-nav">
          <a href="/blog" class="btn-secondary">&lt;- Back to writing</a>
        </div>
      </article>
    </main>

    <Footer />

    <script>import "../scripts/blog-reading-progress";</script>
  </body>
</html>
