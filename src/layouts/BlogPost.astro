---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];
const { title, description, pubDate, updatedDate, tags } = Astro.props;
const slug = Astro.url.pathname.split("/").filter(Boolean).pop();
const ogImage = `/rajatjog-website/og/${slug}.png`;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const formattedUpdated = updatedDate?.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage} type="article" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      author: { "@type": "Person", name: "Rajat Jog", url: "https://RJ-Gamer.github.io/rajatjog-website" },
      image: new URL(ogImage, Astro.site).toString(),
      url: Astro.url.toString(),
    })} />
  </head>
  <body>
    <Header />
    <div class="reading-progress" id="readingProgress"></div>

    <main class="article-shell">
      <a href="/rajatjog-website/blog" class="back-link">&lt;- All posts</a>

      <article class="post" id="article">
        <header class="post-header page-header">
          <span class="page-kicker">Writing</span>
          {tags && tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag: string) => <span class="chip active">{tag}</span>)}
            </div>
          )}
          <h1>{title}</h1>
          <p class="post-description page-subtitle">{description}</p>
          <div class="post-meta">
            <div class="author-mark">RJ</div>
            <div>
              <strong>Rajat Jog</strong>
              <span>Senior Backend Engineer</span>
            </div>
            <i></i>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {formattedUpdated && <span>Updated {formattedUpdated}</span>}
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        <footer class="author-card">
          <div class="author-mark large">RJ</div>
          <div>
            <h2>Rajat Jog</h2>
            <p>
              Senior Backend Engineer from Pune, India. Specialises in Python,
              Django, and FastAPI. Builds reliable production systems and
              open-sources the hard parts.
            </p>
            <div class="author-links">
              <a href="https://linkedin.com/in/rajat-jog" target="_blank" rel="noopener">LinkedIn -></a>
              <a href="https://github.com/RJ-Gamer" target="_blank" rel="noopener">GitHub -></a>
              <a href="https://pypi.org/user/rajatjog1294" target="_blank" rel="noopener">PyPI -></a>
            </div>
          </div>
        </footer>

        <div class="post-nav">
          <a href="/rajatjog-website/blog" class="btn-secondary">&lt;- Back to writing</a>
        </div>
      </article>
    </main>

    <Footer />

    <script>
      const progress = document.getElementById("readingProgress");
      const article = document.getElementById("article");

      function updateProgress() {
        if (!progress || !article) return;
        const rect = article.getBoundingClientRect();
        const available = rect.height - window.innerHeight;
        const percent = available > 0 ? Math.min(100, Math.max(0, (-rect.top / available) * 100)) : 0;
        progress.style.width = `${percent}%`;
      }

      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);
    </script>
  </body>
</html>

<style>
  .reading-progress {
    background: var(--color-accent);
    height: 2px;
    left: 0;
    position: fixed;
    top: 60px;
    width: 0;
    z-index: 101;
  }

  .article-shell {
    max-width: 980px;
  }

  .back-link {
    align-items: center;
    color: var(--color-text-muted);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin-bottom: 3rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post {
    margin: 0 auto;
    max-width: var(--content-width);
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
  }

  .chip.active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent-border);
    color: var(--color-accent);
  }

  .post-header h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    max-width: 760px;
  }

  .post-description {
    font-size: 1.05rem;
    max-width: 640px;
  }

  .post-meta {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .post-meta div:not(.author-mark) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .post-meta strong {
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .post-meta span,
  .post-meta time {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-style: normal;
  }

  .post-meta i {
    background: var(--color-border);
    display: block;
    height: 28px;
    width: 1px;
  }

  .author-mark {
    align-items: center;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent-border);
    border-radius: 999px;
    color: var(--color-accent);
    display: inline-flex;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    height: 32px;
    justify-content: center;
    width: 32px;
  }

  .author-mark.large {
    font-size: 0.85rem;
    height: 48px;
    width: 48px;
  }

  .author-card {
    background: var(--color-surface-strong);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-accent);
    display: flex;
    gap: 1.5rem;
    margin-top: 5rem;
    padding: 2rem;
  }

  .author-card h2 {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .author-card p {
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .author-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .author-links a {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .author-links a:hover {
    color: var(--color-accent);
  }

  .post-nav {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding-top: 2rem;
  }

  @media (max-width: 640px) {
    .post-meta i {
      display: none;
    }

    .author-card {
      flex-direction: column;
      padding: 1.5rem;
    }
  }
</style>
